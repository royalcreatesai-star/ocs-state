#!/usr/bin/env python3
"""
PreToolUse hook — restricts Bash access to /ME/Ai and system paths.
Blocks any command that explicitly references a /Users/iglobalian/ path
outside the allowed directory.
"""
import sys
import json
import re

ALLOWED_USER_PATHS = [
    "/Users/iglobalian/Library/Mobile Documents/com~apple~CloudDocs/ME/Ai",
    "/Users/iglobalian/.claude",
    "/Users/iglobalian/Library/Application Support/Claude",
    "/Users/iglobalian/Library/Application Support/claude",
    "/Users/iglobalian/Documents/ME/Ai/ocs-state",  # OCS state repo (git; iCloud blocks .git)
]

def extract_paths(cmd: str):
    paths = []
    # Double-quoted paths (handles spaces like "Mobile Documents")
    paths += re.findall(r'"(/Users/iglobalian/[^"]+)"', cmd)
    # Single-quoted paths
    paths += re.findall(r"'(/Users/iglobalian/[^']+)'", cmd)
    # Unquoted paths (no spaces — stops at whitespace/shell metacharacters)
    paths += re.findall(r'(?<!["\'])(/Users/iglobalian/[^\s\'";&|>)\\]+)', cmd)
    return paths

def main():
    try:
        data = json.load(sys.stdin)
    except Exception:
        sys.exit(0)

    cmd = data.get("tool_input", {}).get("command", "")
    blocked = []
    for path in extract_paths(cmd):
        path = path.rstrip(")'\"\\ ")
        if not any(path.startswith(a) for a in ALLOWED_USER_PATHS):
            blocked.append(path)

    if blocked:
        out = {
            "hookSpecificOutput": {
                "hookEventName": "PreToolUse",
                "permissionDecision": "deny",
                "permissionDecisionReason": (
                    f"Blocked: path outside /ME/Ai — {', '.join(blocked[:3])}"
                ),
            }
        }
        print(json.dumps(out))

if __name__ == "__main__":
    main()
